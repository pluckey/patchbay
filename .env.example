# --- LLM providers (at least one required) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
XAI_API_KEY=
GOOGLE_API_KEY=
OPEN_ROUTER_API_KEY=

# --- Gateway / routing (optional) ---
PORTKEY_API_KEY=
PORTKEY_MODEL_ID=

# --- Persistence (optional — defaults to filesystem under .context-canvas/) ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=

# --- Auth (optional) ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in

# --- Rate limiting (optional) ---
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
RATE_LIMIT_ANON_PER_MINUTE=10
RATE_LIMIT_ANON_PER_DAY=100
RATE_LIMIT_AUTH_PER_MINUTE=60
RATE_LIMIT_AUTH_PER_DAY=1000

# --- Observability (optional) ---
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# --- Test users (optional, for E2E) ---
TEST_USER_EMAIL=
TEST_USER_PASSWORD=
